# This is an example environment file for flatnotes.
# To use it, copy this file to `.env` (`cp .env.example .env`)
# and then customize the values to your needs.
#
# When using docker-compose, the `.env` file is loaded automatically.
# When using docker run, you can use the --env-file ./.env flag.

################################################################################
# 1. Core Flatnotes Configuration
################################################################################

# (Optional) The host flatnotes will bind to inside the container.
# Default: 0.0.0.0
# FLATNOTES_HOST=0.0.0.0

# (Optional) The port flatnotes will bind to inside the container.
# Default: 8080
# FLATNOTES_PORT=8080

# (Optional) For Docker, sets the user/group ID to run the application as,
# which helps manage file permissions on the mounted /data volume.
# If your host machine's user ID (UID) or group ID (GID) is different from 1000,
# you must set the PUID and PGID environment variables below to match your host user's IDs.
# Run `id -u` and `id -g` on your host to get the current user's values.
# Default: 1000
# PUID=1000
# PGID=1000


################################################################################
# 2. Authentication
################################################################################

# (Optional) The authentication type.
# - "none": No authentication. Anyone can read/write.
# - "read_only": No authentication, but creating/editing/deleting is disabled.
# - "password": (Default) Username and password required.
# - "totp": Username, password, and a Time-based One-Time Password (TOTP) required.
# Default: password
FLATNOTES_AUTH_TYPE=none

# (Required if AUTH_TYPE is 'password' or 'totp') The username for login.
# FLATNOTES_USERNAME=user

# (Required if AUTH_TYPE is 'password' or 'totp') The password for login.
# FLATNOTES_PASSWORD=changeMe!

# (Required if AUTH_TYPE is 'password' or 'totp') The secret key for signing session tokens.
# !! IMPORTANT !! Change this to a long, random string for security.
# FLATNOTES_SECRET_KEY=aLongAndVeryRandomSeriesOfCharactersForSecurity

# (Optional) Session token validity period in days.
# Default: 30
# FLATNOTES_SESSION_EXPIRY_DAYS=30

# (Required if AUTH_TYPE is 'totp') The secret key for generating TOTP codes.
# On first startup, a QR code will be printed to the container logs for you to scan.
# Change this to another long, random string.
# FLATNOTES_TOTP_KEY=YourSuperSecretTOTPKeyHere


################################################################################
# 3. Quick Access (Home Page Module)
################################################################################

# (Optional) Set to "true" to hide the quick access notes on the home page.
# Default: false
# FLATNOTES_QUICK_ACCESS_HIDE=false

# (Optional) The title for the quick access section.
# Default: RECENTLY MODIFIED
# FLATNOTES_QUICK_ACCESS_TITLE="Recently Modified Notes"

# (Optional) The search term to populate the quick access notes.
# Use "*" for all notes, or something like "#pinned" to show only notes with that tag.
# Default: *
# FLATNOTES_QUICK_ACCESS_TERM="*"

# (Optional) The sort order for quick access notes.
# Must be one of: score, title, lastModified
# Default: lastModified
# FLATNOTES_QUICK_ACCESS_SORT=lastModified

# (Optional) The maximum number of notes to show in the quick access section.
# Default: 4
# FLATNOTES_QUICK_ACCESS_LIMIT=5


################################################################################
# 4. Advanced Configuration
################################################################################

# (Optional) Use if hosting flatnotes at a sub-path (e.g., your.domain/notes).
# !! IMPORTANT !! Must start with "/" and not end with "/". Example: /notes
# Default: (empty string)
# FLATNOTES_PATH_PREFIX=


################################################################################
# 5. Git Integration (flatnotes-git-sync)
################################################################################

# (Required) Set to "true" to enable the Git integration feature.
# This will add a Git Sync panel to the UI and enable the Git API endpoints.
# Default: false
FLATNOTES_GIT_ENABLED=true

# --- The following variables are effective only when FLATNOTES_GIT_ENABLED is true ---

# (Optional) The name of the remote repository to use for pull/push operations.
# Default: origin
FLATNOTES_GIT_REMOTE_NAME=origin

# (Optional) The default branch name to use for pull/push operations.
# Default: main
FLATNOTES_GIT_DEFAULT_BRANCH=main

# (Optional) The username to use when creating commits.
# If left empty, Git's system or repository-level configuration will be used.
FLATNOTES_GIT_COMMIT_USER_NAME=flatnotes-bot

# (Optional) The email address to use when creating commits.
# If left empty, Git's system or repository-level configuration will be used.
FLATNOTES_GIT_COMMIT_USER_EMAIL=bot@flatnotes.local

# (Optional) If true, automatically runs `git init` if the notes
# directory is not a Git repository. Defaults to `false`.
FLATNOTES_GIT_AUTO_INIT=false

# (Optional) The pull strategy to use when syncing.
# Can be 'rebase' (default) or 'merge'.
# 'rebase' keeps a cleaner, linear history.
# 'merge' creates a merge commit, preserving the exact history of branches.
FLATNOTES_GIT_PULL_STRATEGY=rebase

# (Optional) Interval in minutes for automatic background fetching.
# This periodically runs `git fetch` to check for remote changes. It is a
# fallback mechanism and is automatically disabled if a Webhook Secret is set.
# Set to 0 to disable. A value of 1-4 is not recommended for performance reasons.
# Default: 0 (disabled)
FLATNOTES_GIT_AUTO_FETCH_INTERVAL=0

# (Optional) Set a long, random secret key to enable and secure the webhook endpoint.
# This allows for real-time updates from your Git provider (e.g., GitHub) and is the
# recommended method for automatic updates. If this key is set and is at least 16
# characters long, the webhook feature will be activated.
# The feature is disabled if this is empty or too short.
#FLATNOTES_GIT_WEBHOOK_SECRET=

################################################################################
# 6. Attachment Storage Configuration
################################################################################

# (Optional) Specifies the PREFERRED storage for NEWLY uploaded attachments.
# Note: Flatnotes will always serve existing local files from the 'attachments' 
# subfolder, regardless of this setting.
#
# - "filesystem": (Default) Stores new attachments in a subfolder named 'attachments' 
#                 within your notes directory. This is the most portable option.
# - "s3":         Stores new attachments in an S3-compatible object storage. This
#                 requires the bucket or custom domain to be publicly accessible.
#
# UPLOAD FALLBACK: If 's3' is chosen but an upload fails for any reason,
# Flatnotes will automatically save the attachment to the local 'filesystem'
# as a fallback to prevent data loss.
#
# Default: filesystem
FLATNOTES_ATTACHMENT_STORAGE_PROVIDER=filesystem

# --- S3/R2 Provider Settings (effective only if provider is 's3') ---

# (Required for R2, MinIO, etc. | Optional for AWS S3) 
# The full API endpoint URL for your S3-compatible service.
# For Cloudflare R2: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# For AWS S3: You can leave this blank and only set the region.
FLATNOTES_S3_ENDPOINT_URL=

# (Required if provider is 's3') Your S3 Access Key ID.
FLATNOTES_S3_ACCESS_KEY_ID=

# (Required if provider is 's3') Your S3 Secret Access Key.
FLATNOTES_S3_SECRET_ACCESS_KEY=

# (Required if provider is 's3') The name of the S3 bucket to upload files to.
# This bucket MUST be configured for public access; flatnotes does not set
# object ACL headers during upload, which keeps Cloudflare R2 compatible.
FLATNOTES_S3_BUCKET_NAME=

# (Required for AWS S3 | Recommended for R2) The region of your bucket.
# For AWS S3: e.g., "us-east-1"
# For Cloudflare R2: Set this to "auto".
FLATNOTES_S3_REGION=auto

# (Required if provider is 's3') The public base URL for accessing your bucket's content.
# This URL should not end with a slash. The final URL in your note will be:
# {FLATNOTES_S3_PUBLIC_URL}/{object-key}
#
# Example for R2 Public Domain: https://pub-xxxxxxxx.r2.dev
# Example for AWS S3 with public access: https://your-bucket-name.s3.your-region.amazonaws.com
# Example for a custom domain (e.g., via CloudFront): https://cdn.your-domain.com
FLATNOTES_S3_PUBLIC_URL=

# (Optional) A prefix to add to all uploaded file paths within the bucket.
# This acts like a virtual subfolder. E.g., "attachments".
# If set, the final URL will be: {FLATNOTES_S3_PUBLIC_URL}/{FLATNOTES_S3_PATH_PREFIX}/{object-key}
# FLATNOTES_S3_PATH_PREFIX=

################################################################################
# 7. Frontend Image Processing
################################################################################

# (Optional) Enable/disable client-side image compression before uploading.
# Disabling this will upload original, uncompressed images.
# Default: true
FLATNOTES_FRONTEND_IMAGE_COMPRESSION_ENABLED=true

# (Optional) Set the compression quality for images (0.1 to 1.0).
# Lower values mean smaller file size but lower quality.
# Default: 0.8
FLATNOTES_FRONTEND_IMAGE_COMPRESSION_QUALITY=0.8

# (Optional) Set the maximum width for uploaded images.
# Images wider than this will be scaled down, preserving aspect ratio.
# Default: 1920
FLATNOTES_FRONTEND_IMAGE_MAX_WIDTH=1920
