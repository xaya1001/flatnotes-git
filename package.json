{
  "name": "flatnotes",
  "version": "5.5.4",
  "type": "module",
  "description": "A database-less note taking web app that utilises a flat folder of markdown files for storage.",
  "main": "client/index.html",
  "scripts": {
    "git-test": "pipenv run pytest && vitest --coverage --root .",
    "test:py": "pipenv run pytest",
    "test:js": "vitest --coverage --root .",
    "prepare": "husky",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "vite build",
    "watch": "vite build --watch",
    "dev": "vite"
  },
  "author": "Adam Dullage",
  "license": "MIT",
  "dependencies": {
    "@jamescoyle/vue-icon": "0.1.2",
    "@mdi/js": "7.4.47",
    "@mdi/light-js": "0.2.63",
    "@toast-ui/editor": "3.2.2",
    "@toast-ui/editor-plugin-code-syntax-highlight": "3.1.0",
    "axios": "1.12.2",
    "compressorjs": "^1.2.1",
    "mermaid": "^11.7.0",
    "mitt": "^3.0.1",
    "mousetrap": "1.6.5",
    "pinia": "3.0.3",
    "primevue": "3.53.1",
    "uuid": "^11.1.0",
    "vue": "3.5.22",
    "vue-router": "4.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "10.4.21",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.2",
    "postcss": "8.5.6",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "0.6.14",
    "sass-embedded": "1.93.2",
    "tailwindcss": "3.4.18",
    "vite": "7.1.9",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{js,vue,ts,jsx,tsx}": [
      "prettier --write"
    ],
    "*.{json,html,css,scss,md}": "prettier --write",
    "*.py": [
      "pipenv run isort",
      "pipenv run black",
      "pipenv run flake8"
    ]
  }
}
